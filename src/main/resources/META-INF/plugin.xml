<?xml version="1.0" encoding="UTF-8"?>
<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
  <!-- Unique identifier of the plugin. It should be FQN. It cannot be changed between the plugin versions. -->
  <id>com.connecthid.intellij</id>

  <!-- Public plugin name should be written in Title Case.
       Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-name -->
  <name>ConnectHID</name>

  <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
  <vendor email="support@connecthid.com" url="https://connecthid.com">ConnectHID</vendor>

  <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
       Simple HTML elements (text formatting, paragraphs, and lists) can be added inside of <![CDATA[ ]]> tag.
       Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-description -->
  <description><![CDATA[
    ConnectHID is an IntelliJ IDEA plugin for cloud and server management.
    Features include:
    - Two-way code synchronization
    - Server monitoring
    - Docker container management
    - Script management
    - Cron job management
    - Database management
    - Application deployment
  ]]></description>

  <depends>com.intellij.modules.platform</depends>
  <depends>com.intellij.modules.lang</depends>
  <depends>org.jetbrains.plugins.terminal</depends>


  <extensions defaultExtensionNs="com.intellij">
      <applicationService serviceImplementation="com.connecthid.intellij.services.ServerConnectionService"/>
      <postStartupActivity implementation="com.connecthid.intellij.ConnectHIDStartupActivity"/>
    <toolWindow
            id="Connect HID"
            icon="icons/connecthid.svg"
            anchor="right"
            factoryClass="com.connecthid.intellij.ConnectHIDPlugin"/>
    <notificationGroup
            id="notification.groupId.connecthid"
            displayType="BALLOON" bundle="messages.PluginBundle"
            key="notification.group.notification.groupid.connecthid"/>

    <configurationType
            implementation="com.connecthid.intellij.ui.runconfigurations.ConnectHIDRunConfigurationType"/>


    <searchEverywhereContributor implementation="com.connecthid.intellij.ui.filemanager.sftp.search.SftpFileContributorFactory"/>
      <virtualFileSystem key="sftp" implementationClass="com.connecthid.intellij.connection.sftp.SftpFileSystem"/>



  </extensions>

  <actions>

  </actions>

</idea-plugin>